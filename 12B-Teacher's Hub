    <script>
        // --- 1. Live Time Tick Handler ---
        function updateDateTime() {
            const now = new Date();
            const options = { 
                weekday: 'short', year: 'numeric', month: 'short', day: 'numeric', 
                hour: '2-digit', minute: '2-digit', second: '2-digit' 
            };
            document.getElementById('live-datetime').textContent = now.toLocaleDateString('en-US', options);
        }
        setInterval(updateDateTime, 1000);
        updateDateTime();

        // --- 2. Canvas Rain System Loop ---
        const canvas = document.getElementById('weather-canvas');
        const ctx = canvas.getContext('2d');
        let rainDrops = [];
        let rainAnimationId = null;

        function resizeCanvas() {
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
        }
        window.addEventListener('resize', resizeCanvas);
        resizeCanvas();

        class Drop {
            constructor() {
                this.reset();
                this.y = Math.random() * canvas.height; 
            }
            reset() {
                this.x = Math.random() * canvas.width;
                this.y = -20;
                this.length = Math.random() * 15 + 10;
                this.speed = Math.random() * 12 + 18;
                this.opacity = Math.random() * 0.3 + 0.2;
            }
            update() {
                this.y += this.speed;
                if (this.y > canvas.height) {
                    this.reset();
                }
            }
            draw() {
                ctx.beginPath();
                ctx.strokeStyle = `rgba(154, 185, 196, ${this.opacity})`;
                ctx.lineWidth = 1.5;
                ctx.moveTo(this.x, this.y);
                ctx.lineTo(this.x, this.y + this.length);
                ctx.stroke();
            }
        }

        function startRainLoop() {
            if (rainAnimationId) return;
            rainDrops = [];
            for (let i = 0; i < 90; i++) {
                rainDrops.push(new Drop());
            }
            function run() {
                ctx.clearRect(0, 0, canvas.width, canvas.height);
                rainDrops.forEach(drop => {
                    drop.update();
                    drop.draw();
                });
                rainAnimationId = requestAnimationFrame(run);
            }
            run();
        }

        function stopRainLoop() {
            if (rainAnimationId) {
                cancelAnimationFrame(rainAnimationId);
                rainAnimationId = null;
            }
            ctx.clearRect(0, 0, canvas.width, canvas.height);
        }

        // --- 3. Geo Location -> Open-Meteo API Connector ---
        function applyWeatherUI(isRainy, debugInfo = "") {
            const body = document.body;
            const header = document.getElementById('main-header');
            const timeBadge = document.getElementById('time-badge');
            const glow = document.getElementById('weather-glow');
            const subtitle = document.getElementById('weather-subtitle');
            const statusText = document.getElementById('weather-status-text');

            if (isRainy) {
                body.className = "weather-rainy text-stone-700 min-h-screen flex flex-col";
                header.className = "bg-[#456b66] text-white border-b-4 border-[#324f4b] sticky top-0 z-40 shadow-sm h-24 md:h-28 flex items-center transition-colors duration-500";
                timeBadge.className = "text-right bg-[#385652] px-2.5 py-1 sm:px-4 sm:py-1.5 rounded-2xl border border-[#2b423f] transition-colors duration-500";
                glow.style.opacity = "0";
                subtitle.textContent = "STEM Hub 🌧️ (Overcast Rain)";
                statusText.textContent = "🌧️ Rainy Forecast " + debugInfo;
                startRainLoop();
            } else {
                body.className = "weather-sunny text-stone-700 min-h-screen flex flex-col";
                header.className = "bg-[#5cc4ba] text-white border-b-4 border-[#469e96] sticky top-0 z-40 shadow-sm h-24 md:h-28 flex items-center transition-colors duration-500";
                timeBadge.className = "text-right bg-[#4faaa0] px-2.5 py-1 sm:px-4 sm:py-1.5 rounded-2xl border border-[#3f8e85] transition-colors duration-500";
                glow.style.opacity = "1";
                subtitle.textContent = "STEM Hub ☀️ (Clear Skies)";
                statusText.textContent = "☀️ Sunny Forecast " + debugInfo;
                stopRainLoop();
            }
        }

        async function fetchRealWeather(lat, lon) {
            try {
                const response = await fetch(`https://api.open-meteo.com/v1/forecast?latitude=${lat}&longitude=${lon}&current_weather=true`);
                const data = await response.json();
                const weatherCode = data.current_weather.weathercode;
                
                const rainyCodes = [51, 53, 55, 56, 57, 61, 63, 65, 66, 67, 80, 81, 82];
                const isRainy = rainyCodes.includes(weatherCode);
                
                applyWeatherUI(isRainy);
            } catch (error) {
                console.error("Weather API read failed, using sunny fallback.", error);
                applyWeatherUI(false, "(Default)");
            }
        }

        if (navigator.geolocation) {
            navigator.geolocation.getCurrentPosition(
                (pos) => {
                    fetchRealWeather(pos.coords.latitude, pos.coords.longitude);
                },
                (err) => {
                    console.log("Location access denied or timed out. Defaulting to Sunny.");
                    applyWeatherUI(false, "(Default)");
                },
                { timeout: 7000 }
            );
        } else {
            applyWeatherUI(false, "(Unsupported)");
        }

        // --- 4. Autoplay Background Music Subsystem ---
        const audio = document.getElementById('bg-audio');
        const audioWidget = document.getElementById('audio-control-widget');
        const audioIcon = document.getElementById('audio-widget-icon');
        const audioText = document.getElementById('audio-widget-text');

        function updateWidgetUI(isPlaying) {
            if (isPlaying) {
                audioIcon.className = "fa-solid fa-compact-disc animate-spin text-emerald-300";
                audioText.textContent = "Music Playing";
                audioWidget.className = "flex items-center space-x-2 bg-emerald-900/40 hover:bg-emerald-900/60 text-white px-3 py-1.5 rounded-2xl border border-emerald-500/30 transition-all text-xs font-semibold shadow-inner";
            } else {
                audioIcon.className = "fa-solid fa-circle-play text-amber-300";
                audioText.textContent = "Music Paused";
                audioWidget.className = "flex items-center space-x-2 bg-amber-900/30 hover:bg-amber-900/50 text-white px-3 py-1.5 rounded-2xl border border-amber-500/30 transition-all text-xs font-semibold";
            }
        }

        function attemptAutoplay() {
            audio.play().then(() => {
                updateWidgetUI(true);
                // If playback succeeds, we can remove the global interaction listeners
                removeInteractionListeners();
            }).catch(error => {
                // Autoplay blocked by browser policy; wait for manual user interaction
                updateWidgetUI(false);
                console.log("Browser policy blocked instant autoplay. Awaiting first user gesture...");
            });
        }

        // Handle user interaction with the dedicated header control widget
        audioWidget.addEventListener('click', () => {
            if (audio.paused) {
                audio.play();
                updateWidgetUI(true);
            } else {
                audio.pause();
                updateWidgetUI(false);
            }
        });

        // Trigger audio initialization on any generic interaction across the page window
        function triggerOnInteraction() {
            if (audio.paused) {
                attemptAutoplay();
            }
        }

        function removeInteractionListeners() {
            window.removeEventListener('click', triggerOnInteraction);
            window.removeEventListener('touchstart', triggerOnInteraction);
            window.removeEventListener('keydown', triggerOnInteraction);
        }

        // Setup early window event hooks to catch quick navigation clicks
        window.addEventListener('click', triggerOnInteraction);
        window.addEventListener('touchstart', triggerOnInteraction);
        window.addEventListener('keydown', triggerOnInteraction);

        // Run an instant start routine once files load up completely
        window.addEventListener('DOMContentLoaded', () => {
            audio.volume = 0.40; // Set safe comfortable volume level
            attemptAutoplay();
        });
    </script>
</body>
</html>
