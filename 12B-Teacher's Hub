        /* Weather Style states applied dynamically to body */
        body {
            font-family: 'Quicksand', sans-serif;
            transition: background-color 0.5s ease;
        }
        
        /* Default / Sunny Backdrop Style */
        body.weather-sunny {
            background-color: #f6ebd3; 
            background-image: radial-gradient(#eadeca 1.5px, transparent 1.5px);
            background-size: 24px 24px;
        }

        /* Rainy Backdrop Style */
        body.weather-rainy {
            background-color: #cfdcd6;
            background-image: radial-gradient(#b0c2bc 1.5px, transparent 1.5px);
            background-size: 24px 24px;
        }

        /* Custom Card-Style Border & Shadow combo */
        .ac-card {
            background-color: #fffdf9;
            border: 4px solid #ebdcb9;
            border-radius: 2rem;
            box-shadow: 0 8px 0px 0px #e1cca3;
            transition: all 0.2s ease-in-out;
        }
        .ac-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 0px 0px #e1cca3;
        }
        .ac-btn {
            border: 3px solid rgba(0,0,0,0.15);
            box-shadow: 0 4px 0px 0px rgba(0,0,0,0.15);
            transition: all 0.1s ease;
        }
        .ac-btn:active {
            transform: translateY(3px);
            box-shadow: 0 1px 0px 0px rgba(0,0,0,0.15);
        }

        /* Custom lively jumping animation */
        @keyframes ac-jump {
            0%, 100% {
                transform: translateY(0);
                animation-timing-function: cubic-bezier(0.215, 0.610, 0.355, 1);
            }
            50% {
                transform: translateY(-14px);
                animation-timing-function: cubic-bezier(0.755, 0.050, 0.855, 0.060);
            }
        }
        .animate-jump {
            animation: ac-jump 0.9s infinite;
        }

        /* Rain Overlay Canvas Setup */
        #weather-canvas {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 99;
        }
    </style>
